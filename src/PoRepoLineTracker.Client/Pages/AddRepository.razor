@page "/add-repository"
@attribute [Authorize]
@inject HttpClient Http
@inject ILogger<AddRepository> Logger
@inject NavigationManager Navigation
@inject DialogService DialogService
@using PoRepoLineTracker.Client.Models
@using PoRepoLineTracker.Domain.Models
@using PoRepoLineTracker.Application.Models
@using Radzen.Blazor
@using Microsoft.AspNetCore.Authorization

<RadzenStack Gap="1rem">
    <RadzenText TextStyle="TextStyle.H4" Style="margin: 0 0 0.5rem 0;">Add Repositories</RadzenText>

    @if (!string.IsNullOrEmpty(pageState.ErrorMessage) && !pageState.ShowRepositorySelector)
    {
        <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" Variant="Variant.Flat"
                     Close="@(() => pageState.ErrorMessage = string.Empty)">
            @pageState.ErrorMessage
        </RadzenAlert>
    }

    @if (!string.IsNullOrEmpty(pageState.AddRepoMessage))
    {
        <RadzenAlert AlertStyle="AlertStyle.Success" ShowIcon="true" Variant="Variant.Flat"
                     Close="@(() => pageState.AddRepoMessage = string.Empty)">
            @pageState.AddRepoMessage
        </RadzenAlert>
    }

    @if (pageState.ShowRepositorySelector)
    {
        <RadzenCard>
            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center" Style="margin-bottom: 1rem;">
                <RadzenText TextStyle="TextStyle.H6" Style="margin: 0;">Select Repositories from Your GitHub Account</RadzenText>
                <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text" Click="HideRepositorySelection" />
            </RadzenStack>
            @if (pageState.IsLoadingGitHubRepos)
            {
                <RadzenStack AlignItems="AlignItems.Center" class="rz-p-4">
                    <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
                    <RadzenText TextStyle="TextStyle.Body2"><em>Loading your GitHub repositories...</em></RadzenText>
                </RadzenStack>
            }
            else if (pageState.GitHubUserRepositories.Any())
            {
                <RadzenStack Style="margin-bottom: 1rem;">
                    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center" Style="margin-bottom: 0.5rem;">
                        <RadzenText TextStyle="TextStyle.Caption">Found @pageState.GitHubUserRepositories.Count repositories</RadzenText>
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                            <RadzenButton Text="Select All" ButtonStyle="ButtonStyle.Secondary" Variant="Variant.Outlined" Size="ButtonSize.Small" Click="SelectAllRepositories" />
                            <RadzenButton Text="Clear All" ButtonStyle="ButtonStyle.Light" Variant="Variant.Outlined" Size="ButtonSize.Small" Click="ClearAllSelections" />
                        </RadzenStack>
                    </RadzenStack>

                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem" Style="margin-bottom: 0.5rem;">
                            <RadzenIcon Icon="search" Style="color: var(--rz-text-secondary-color);" />
                            <RadzenTextBox @bind-Value="_repoFilterText" Placeholder="Filter repositories..." Style="width: 100%;" />
                            @if (!string.IsNullOrEmpty(_repoFilterText))
                            {
                                <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text" Size="ButtonSize.Small"
                                              Click="@(() => _repoFilterText = string.Empty)" title="Clear filter" />
                            }
                        </RadzenStack>

                        <RadzenListBox Value="@_selected"
                                       ValueChanged="@((IEnumerable<GitHubUserRepositoryDto> v) => { _selected = v; StateHasChanged(); })"
                                       Multiple="true"
                                       Data="@FilteredGitHubRepos"
                                       TValue="IEnumerable<GitHubUserRepositoryDto>"
                                       TextProperty="FullName"
                                       Style="height: 360px; width: 100%;" />
                    </RadzenStack>

                    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center" Style="margin-top: 1rem;">
                        <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-text-secondary-color);">
                            @(_selected.Count()) selected
                        </RadzenText>
                        <RadzenButton Text="Add Selected Repositories"
                                      Icon="add_circle"
                                      ButtonStyle="ButtonStyle.Primary"
                                      Click="AddSelectedRepositories"
                                      IsBusy="@pageState.IsAddingRepository"
                                      BusyText="Adding..."
                                      Disabled="@(!_selected.Any() || pageState.IsAddingRepository)" />
                    </RadzenStack>
            }
            else
            {
                <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" Variant="Variant.Flat">
                    <RadzenText TextStyle="TextStyle.Subtitle2">No Repositories Found</RadzenText>
                    @if (!string.IsNullOrEmpty(pageState.ErrorMessage))
                    {
                        <RadzenText>@pageState.ErrorMessage</RadzenText>
                    }
                    else
                    {
                        <RadzenText>No repositories were found in your GitHub account.</RadzenText>
                    }
                    <RadzenText TextStyle="TextStyle.Body2">
                        <strong>Please ensure:</strong><br />
                        * Your GitHub Personal Access Token is properly configured in Settings<br />
                        * The token has the required permissions (repo scope)<br />
                        * You have at least one repository in your GitHub account
                    </RadzenText>
                </RadzenAlert>
            }
        </RadzenCard>
    }

    @* Single repository mode removed as requested *@

    @if (pageState.IsAddingRepository)
    {
        <RadzenCard>
            <RadzenProgressBar Value="@pageState.ProgressPercentage" ShowValue="true" />
            <RadzenText TextStyle="TextStyle.Caption" Style="text-align: center; margin-top: 0.5rem;">@pageState.ProgressMessage</RadzenText>
        </RadzenCard>
    }
</RadzenStack>
@code {
    private RepositoryPageState pageState = new();
    // #7 fix: removed duplicate @inject Http and @inject Logger that were here inside @code —
    // they are already declared at the top of the file (lines 3-4)

    protected override async Task OnInitializedAsync()
    {
        pageState.ShowRepositorySelector = true;
        await LoadGitHubRepositories();
    }

    private async Task LoadGitHubRepositories()
    {
        pageState.IsLoadingGitHubRepos = true;
        pageState.ErrorMessage = string.Empty;
        StateHasChanged();
        
        try
        {
            var response = await Http.GetAsync("/api/github/user-repositories");
            
            if (response.IsSuccessStatusCode)
            {
                var gitHubRepos = await response.Content.ReadFromJsonAsync<List<GitHubUserRepositoryDto>>();
                // Sort repositories alphabetically by name
                pageState.GitHubUserRepositories = gitHubRepos?.OrderBy(r => r.Name).ToList() ?? new List<GitHubUserRepositoryDto>();
                Logger.LogInformation("Loaded {Count} GitHub user repositories.", pageState.GitHubUserRepositories.Count);
            }
            else
            {
                var errorMessage = await response.Content.ReadAsStringAsync();
                Logger.LogWarning("Failed to load GitHub repositories: {StatusCode} - {ErrorMessage}", response.StatusCode, errorMessage);
                pageState.ErrorMessage = $"Unable to load repositories: {errorMessage}";
                pageState.GitHubUserRepositories = new List<GitHubUserRepositoryDto>();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading GitHub repositories: {Message}", ex.Message);
            pageState.ErrorMessage = $"Error loading GitHub repositories: {ex.Message}";
            pageState.GitHubUserRepositories = new List<GitHubUserRepositoryDto>();
        }
        finally
        {
            pageState.IsLoadingGitHubRepos = false;
            StateHasChanged();
        }
    }

    private IEnumerable<GitHubUserRepositoryDto> _selected = Enumerable.Empty<GitHubUserRepositoryDto>();
    private string _repoFilterText = string.Empty;

    private IEnumerable<GitHubUserRepositoryDto> FilteredGitHubRepos =>
        string.IsNullOrWhiteSpace(_repoFilterText)
            ? pageState.GitHubUserRepositories
            : pageState.GitHubUserRepositories
                .Where(r => r.FullName.Contains(_repoFilterText, StringComparison.OrdinalIgnoreCase));

    private void SelectAllRepositories()
    {
        _selected = pageState.GitHubUserRepositories;
        StateHasChanged();
    }

    private void ClearAllSelections()
    {
        _selected = Enumerable.Empty<GitHubUserRepositoryDto>();
        StateHasChanged();
    }

    private async Task AddSelectedRepositories()
    {
        if (pageState.IsAddingRepository || !_selected.Any()) return;
        
        pageState.IsAddingRepository = true;
        pageState.ClearMessages();
        StateHasChanged();
        
        try
        {
            Logger.LogInformation("=== START AddSelectedRepositories ===");
            Logger.LogInformation("Number of selected repositories: {Count}", _selected.Count());
            
            var selectedList = _selected.ToList();
            for (int i = 0; i < selectedList.Count; i++)
            {
                var repo = selectedList[i];
                Logger.LogInformation("Selected Repo [{Index}]: FullName='{FullName}', CloneUrl='{CloneUrl}'", 
                    i, repo.FullName, repo.CloneUrl);
            }
            
            // Step 1: Prepare repository data (25%)
            pageState.SetProgress($"Preparing {_selected.Count()} repositories...", 25);
            StateHasChanged();
            await Task.Delay(300);

            var repositoriesToAdd = _selected.Select(repo =>
            {
                // #9 fix: guard against FullName missing '/' to avoid IndexOutOfRangeException
                var fullNameParts = repo.FullName.Split('/', 2);
                if (fullNameParts.Length < 2)
                {
                    Logger.LogWarning("Unexpected FullName format '{FullName}' — expected 'owner/repo'", repo.FullName);
                    return new BulkRepositoryDto { Owner = repo.FullName, RepoName = repo.Name, CloneUrl = repo.CloneUrl };
                }
                Logger.LogInformation("Splitting FullName '{FullName}' into Owner='{Owner}' and RepoName='{RepoName}'",
                    repo.FullName, fullNameParts[0], fullNameParts[1]);
                    
                return new BulkRepositoryDto
                {
                    Owner = fullNameParts[0],
                    RepoName = fullNameParts[1],
                    CloneUrl = repo.CloneUrl
                };
            }).ToList();

            Logger.LogInformation("Prepared {Count} repositories for API call", repositoriesToAdd.Count);
            
            // Log detailed info about what we're sending
            for (int i = 0; i < repositoriesToAdd.Count; i++)
            {
                var repo = repositoriesToAdd[i];
                Logger.LogInformation("Sending Repo [{Index}]: Owner='{Owner}', RepoName='{RepoName}', CloneUrl='{CloneUrl}'",
                    i, repo.Owner, repo.RepoName, repo.CloneUrl);
            }

            // Step 2: Adding to database (50%)
            pageState.SetProgress("Adding repositories to database...", 50);
            StateHasChanged();

            Logger.LogInformation("Making POST request to /api/repositories/bulk with {Count} repositories", repositoriesToAdd.Count);
            var response = await Http.PostAsJsonAsync("/api/repositories/bulk", repositoriesToAdd);
            
            Logger.LogInformation("Bulk repository add response: Status={StatusCode}", response.StatusCode);
            
            if (response.IsSuccessStatusCode)
            {
                // Step 3: Repositories added successfully (75%)
                pageState.SetProgress("Repositories added! Initializing analysis...", 75);
                StateHasChanged();
                await Task.Delay(500);

                Logger.LogInformation("Reading response content as JSON...");
                var addedRepos = await response.Content.ReadFromJsonAsync<List<GitHubRepository>>();
                
                Logger.LogInformation("API returned {Count} repositories", addedRepos?.Count ?? 0);
                
                if (addedRepos != null && addedRepos.Any())
                {
                    for (int i = 0; i < addedRepos.Count; i++)
                    {
                        var repo = addedRepos[i];
                        Logger.LogInformation("Returned Repo [{Index}]: {Owner}/{Name} (ID: {Id})",
                            i, repo.Owner, repo.Name, repo.Id);
                    }
                }
                else
                {
                    Logger.LogWarning("API returned ZERO repositories! This is the problem!");
                }
                
                // Step 4: Complete (100%)
                pageState.SetProgress("Complete! Repositories are now being analyzed.", 100);
                StateHasChanged();
                await Task.Delay(1000);

                pageState.AddRepoMessage = $"{addedRepos?.Count ?? _selected.Count()} repositories added successfully! Analysis will begin automatically.";
                _selected = Enumerable.Empty<GitHubUserRepositoryDto>(); // Clear selections
                
                // Close dialog (if open) or navigate back to repositories page
                Logger.LogInformation("Closing dialog / navigating to repositories page...");
                await Task.Delay(1500); // Brief delay to show success message
                DialogService.Close(true); // closes dialog when opened as dialog
                Navigation.NavigateTo("/repositories");
            }
            else
            {
                pageState.SetProgress("Error occurred", 100);
                StateHasChanged();
                await Task.Delay(500);

                var errorContent = await response.Content.ReadAsStringAsync();
                Logger.LogError("Bulk repository add failed: Status={StatusCode}, Content={ErrorContent}", response.StatusCode, errorContent);
                pageState.AddRepoMessage = $"Error adding repositories: {response.StatusCode} - {errorContent}";
            }
        }
        catch (Exception ex)
        {
            pageState.SetProgress("Error occurred", 100);
            StateHasChanged();
            await Task.Delay(500);

            pageState.AddRepoMessage = $"Error adding repositories: {ex.Message}";
            Logger.LogError(ex, "Error adding repositories: {Message}", ex.Message);
        }
        finally
        {
            pageState.IsAddingRepository = false;
            pageState.ProgressMessage = string.Empty;
            pageState.ProgressPercentage = 0;
            StateHasChanged();
        }
    }

    private async Task ShowRepositorySelection()
    {
        Logger.LogInformation("ShowRepositorySelection called. Current ShowRepositorySelector: {ShowRepositorySelector}", pageState.ShowRepositorySelector);
        pageState.ShowRepositorySelector = true;
        Logger.LogInformation("ShowRepositorySelector set to true. New value: {ShowRepositorySelector}", pageState.ShowRepositorySelector);
        await LoadGitHubRepositories();
        Logger.LogInformation("LoadGitHubRepositories completed. Calling StateHasChanged.");
        StateHasChanged();
    }

    private void HideRepositorySelection()
    {
        pageState.ShowRepositorySelector = false;
        pageState.ClearSelection();
        StateHasChanged();
    }
}

